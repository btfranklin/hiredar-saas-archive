# --- Secrets (Keep these private!) ---
# Django Core
SECRET_KEY=your_django_secret_key_here # Important: Generate a strong, unique key for production

# API Keys
OPENAI_API_KEY=your-openai-api-key
PINECONE_API_KEY=your-pinecone-api-key

# --- Configuration (defaults in settings.py) ---
# Django Core
DEBUG=True # Set to False in production
ALLOWED_HOSTS=localhost,127.0.0.1 # Add your production domain(s) here

# Database (PostgreSQL)
DB_HOST=db-host.svc.cluster.local
DB_PORT=5432
DB_NAME=hiredar-dev
DB_USER=username
DB_PASSWORD=password

# AI Model Selection
MATCHING_EMBEDDING_MODEL=text-embedding-3-large
RECRUITERS_JOB_PROCESSING_MODEL=gpt-4.1
JOBSEEKERS_RESUME_PROCESSING_MODEL=gpt-4.1
JOBSEEKERS_ROLE_RECOMMENDATION_MODEL=gpt-4.1
JOBSEEKERS_TAGLINE_GENERATION_MODEL=gpt-4.1-mini

# AI Model Configuration (Temperature, Tokens, etc.)
RECRUITERS_JOB_PROCESSING_TEMPERATURE=0.2
JOBSEEKERS_RESUME_PROCESSING_TEMPERATURE=0.7
JOBSEEKERS_RECOMMENDATION_TEMPERATURE=0.7
JOBSEEKERS_TAGLINE_TEMPERATURE=0.7
JOBSEEKERS_TAGLINE_MAX_TOKENS=50

# Pinecone Configuration
PINECONE_INDEX_NAME=job-matcher
PINECONE_DIMENSIONS=3072
PINECONE_PROJECT_NAME=Hiredar
PINECONE_INDEX_HOST= # Often specific to your Pinecone setup/region

# Email
SMTP2GO_API_KEY=your_smtp2go_api_key
DEFAULT_FROM_EMAIL=welcome@hiredar.com

# Social Auth Keys
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Django Q Configuration
DJANGO_Q_WORKERS=1
DJANGO_Q_TIMEOUT=120
DJANGO_Q_RETRY=180
DJANGO_Q_SAVE_LIMIT=10
DJANGO_Q_ORM_BATCH=10
DJANGO_Q_POLL=5

# Sevalla Object Storage info for uploads
SEVALLA_S3_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
SEVALLA_S3_KEY=your_key
SEVALLA_S3_SECRET=your_secret
SEVALLA_S3_BUCKET=hiredar-storage

# Stripe config
STRIPE_SECRET_KEY=sk_test_1234567890
STRIPE_PUBLISHABLE_KEY=pk_test_1234567890
STRIPE_PRICE_ID_100=price_1234567890
STRIPE_PRICE_ID_500=price_1234567890
STRIPE_PRICE_ID_1000=price_1234567890

# QuickEmailVerification config
QUICKEMAILVERIFICATION_API_KEY=your_quickemailverification_api_key