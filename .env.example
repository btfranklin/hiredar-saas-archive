# Django Core
DEBUG=True
# Set to False in production
ALLOWED_HOSTS=localhost,127.0.0.1
# Add your production domain(s) here
SECRET_KEY=your_django_secret_key_here
# Important: Generate a strong, unique key for production

# AI Configuration
OPENAI_API_KEY=your-openai-api-key

# AI Model Configuration
# Matching Analysis (uses o4-mini reasoning model by default)
MATCHING_ANALYSIS_MODEL=o4-mini

# Database (PostgreSQL)
DB_HOST=db-host.svc.cluster.local
DB_PORT=5432
DB_NAME=hiredar-dev
DB_USERNAME=username
DB_PASSWORD=password

# Celery Configuration
CELERY_BROKER_URL="sqla+postgresql+psycopg://username:password@db-host.svc.cluster.local:5432/hiredar-dev"

# Pinecone Configuration
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=job-matcher
PINECONE_DIMENSIONS=3072
PINECONE_PROJECT_NAME=Hiredar
PINECONE_INDEX_HOST=

# Email Configuration
SMTP2GO_API_KEY=your_smtp2go_api_key

# Social Auth Keys
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Sevalla Object Storage info for uploads
SEVALLA_S3_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
SEVALLA_S3_KEY=your_key
SEVALLA_S3_SECRET=your_secret
SEVALLA_S3_BUCKET=hiredar-storage

# Stripe config
STRIPE_SECRET_KEY=sk_test_1234567890
STRIPE_PUBLISHABLE_KEY=pk_test_1234567890
STRIPE_PRICE_ID_100=price_1234567890
STRIPE_PRICE_ID_500=price_1234567890
STRIPE_PRICE_ID_1000=price_1234567890

# QuickEmailVerification config
QUICKEMAILVERIFICATION_API_KEY=your_quickemailverification_api_key
USE_QUICKEMAILVERIFICATION_SANDBOX=True
